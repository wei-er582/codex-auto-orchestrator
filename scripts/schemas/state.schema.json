{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wei-er582/codex-auto-orchestrator/schemas/state.schema.json",
  "title": "Codex Auto Orchestrator durable job state v2",
  "type": "object",
  "required": [
    "version",
    "job_id",
    "status",
    "desired_status",
    "task_path",
    "task_sha256",
    "workspace",
    "workspace_key",
    "origin_thread_id",
    "parent_job_id",
    "controller",
    "heartbeat_at",
    "checkpoint",
    "plan_revision",
    "speed_profile",
    "speed_policy_revision",
    "last_control_seq",
    "workspace_resources",
    "processes",
    "tasks",
    "external_actions"
  ],
  "properties": {
    "version": {"const": 2},
    "job_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["waiting_for_speed", "planning", "running", "validating", "reviewing", "repairing", "integrating", "paused", "interrupted", "complete", "blocked", "cancelled"]},
    "desired_status": {"type": "string"},
    "task_path": {"type": "string", "minLength": 1},
    "task_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "workspace": {"type": "string", "minLength": 1},
    "workspace_key": {"type": "string", "minLength": 1},
    "origin_thread_id": {"type": "string"},
    "parent_job_id": {"type": "string"},
    "controller": {"type": "object"},
    "heartbeat_at": {"type": "string"},
    "checkpoint": {"type": "object"},
    "plan_revision": {"type": "integer", "minimum": 0},
    "speed_profile": {"type": "string"},
    "speed_policy_revision": {"type": "integer", "minimum": 0},
    "last_control_seq": {"type": "integer", "minimum": 0},
    "workspace_resources": {"type": "object"},
    "processes": {"type": "object"},
    "tasks": {"type": "object"},
    "external_actions": {"type": "object"}
  },
  "additionalProperties": true
}
