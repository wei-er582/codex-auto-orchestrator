{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wei-er582/codex-auto-orchestrator/schemas/orchestrator-config.schema.json",
  "title": "Codex Auto Orchestrator profile configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "prompt_policy", "default_profile", "profiles", "updated_at"],
  "properties": {
    "version": {"const": 1},
    "prompt_policy": {"const": "explicit"},
    "default_profile": {"type": "string"},
    "profiles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["matrix", "known_combinations", "catalog_fingerprint", "created_at", "updated_at"],
        "properties": {
          "matrix": {"type": "object"},
          "known_combinations": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "catalog_fingerprint": {"type": "string", "minLength": 1},
          "created_at": {"type": "string", "minLength": 1},
          "updated_at": {"type": "string", "minLength": 1}
        }
      }
    },
    "updated_at": {"type": "string", "minLength": 1}
  }
}
